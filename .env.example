# Copy this file to `.env` and fill in real values.
# `.env` is gitignored — never commit real secrets.
# On Vercel, set these same keys in Project Settings → Environment Variables.

# --- Twilio (SMS + phone verification) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=
TWILIO_PHONE_NUMBER=

# --- Owner / admin contact ---
OWNER_PHONE=

# --- Supabase (database) ---
SUPABASE_URL=
SUPABASE_SECRET_KEY=

# --- Admin dashboard auth ---
ADMIN_PASSWORD=
